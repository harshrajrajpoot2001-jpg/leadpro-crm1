import {
  collection,
  doc,
  setDoc,
  addDoc,
  getDoc,
  getDocs,
  updateDoc,
  deleteDoc,
  onSnapshot,
  query,
  orderBy,
  serverTimestamp,
  Timestamp,
  writeBatch
} from "firebase/firestore";
import { auth, db } from "./firebase";
import { Customer, FollowUp, UserProfile } from "./types";

export enum OperationType {
  CREATE = 'create',
  UPDATE = 'update',
  DELETE = 'delete',
  LIST = 'list',
  GET = 'get',
  WRITE = 'write',
}

export interface FirestoreErrorInfo {
  error: string;
  operationType: OperationType;
  path: string | null;
  authInfo: {
    userId?: string | null;
    email?: string | null;
    emailVerified?: boolean | null;
    isAnonymous?: boolean | null;
    tenantId?: string | null;
    providerInfo?: {
      providerId?: string | null;
      email?: string | null;
    }[];
  };
}

// Custom error logger conforming strictly to FirestoreErrorInfo and throwing a JSON string as mandated
export function handleFirestoreError(error: any, operation: string, collectionName: string): never {
  let opType = OperationType.WRITE;
  const opLower = operation.toLowerCase();
  if (opLower.includes("create") || opLower === "add") {
    opType = OperationType.CREATE;
  } else if (opLower.includes("update")) {
    opType = OperationType.UPDATE;
  } else if (opLower.includes("delete")) {
    opType = OperationType.DELETE;
  } else if (opLower.includes("list") || opLower.includes("subscribe")) {
    opType = OperationType.LIST;
  } else if (opLower.includes("get") || opLower.includes("fetch")) {
    opType = OperationType.GET;
  }

  const currentUser = auth.currentUser;
  const errInfo: FirestoreErrorInfo = {
    error: error instanceof Error ? error.message : String(error),
    operationType: opType,
    path: collectionName,
    authInfo: {
      userId: currentUser?.uid || null,
      email: currentUser?.email || null,
      emailVerified: currentUser?.emailVerified || null,
      isAnonymous: currentUser?.isAnonymous || null,
      tenantId: currentUser?.tenantId || null,
      providerInfo: currentUser?.providerData?.map(provider => ({
        providerId: provider.providerId,
        email: provider.email,
      })) || []
    }
  };

  const jsonString = JSON.stringify(errInfo);
  console.error("Firestore Error Exception Triggered:", jsonString);
  throw new Error(jsonString);
}

// -------------------------------------------------------------------------
// 1. CHANNELS FOR USERS (profiles and roles)
// -------------------------------------------------------------------------

export async function fetchUserProfile(uid: string): Promise<UserProfile | null> {
  try {
    const userDocRef = doc(db, "users", uid);
    const docSnap = await getDoc(userDocRef);
    if (docSnap.exists()) {
      const data = docSnap.data();
      return {
        uid,
        email: data.email || "",
        role: data.role || "staff",
        createdAt: data.createdAt
      };
    }
  } catch (error) {
    handleFirestoreError(error, "get", "users");
  }
  return null;
}

export async function saveUserProfile(uid: string, email: string, role: 'admin' | 'staff'): Promise<void> {
  try {
    const userDocRef = doc(db, "users", uid);
    await setDoc(userDocRef, {
      email,
      role,
      createdAt: serverTimestamp()
    }, { merge: true });
  } catch (error) {
    handleFirestoreError(error, "set", "users");
  }
}

export function subscribeUsers(onUpdate: (users: UserProfile[]) => void, onError?: (err: any) => void) {
  try {
    const usersCollection = collection(db, "users");
    return onSnapshot(usersCollection, (snapshot) => {
      const usersList: UserProfile[] = snapshot.docs.map(d => {
        const data = d.data();
        return {
          uid: d.id,
          email: data.email || "",
          role: data.role || "staff",
          createdAt: data.createdAt
        };
      });
      onUpdate(usersList);
    }, (error) => {
      handleFirestoreError(error, "subscribe", "users");
      if (onError) onError(error);
    });
  } catch (error) {
    console.error("Failed to setup users subscription:", error);
    return () => {};
  }
}

// -------------------------------------------------------------------------
// 2. CHANNELS FOR CUSTOMERS
// -------------------------------------------------------------------------

// Maps DB document representation to UI Customer interface
function docToCustomer(d: any): Customer {
  const data = d.data();
  return {
    id: d.id,
    name: data.customerName || data.name || "Unknown Lead",
    company: data.company || "Unknown Inc.",
    email: data.email || "",
    phone: data.phone || "",
    office: data.office || data.city || "",
    city: data.city || data.office || "",
    leadSource: data.leadSource || "Direct Referral",
    status: data.status || "New",
    lastFollowUpDate: data.lastFollowUpDate || new Date().toISOString().split('T')[0],
    lastFollowUpRel: data.lastFollowUpRel || "Today",
    avatarInitials: data.avatarInitials || "NL",
    isVip: !!data.isVip,
    assignedTo: data.assignedTo || "",
    remark: data.remark || "",
    createdAt: data.createdAt
  };
}

export function subscribeCustomers(onUpdate: (customers: Customer[]) => void, onError?: (err: any) => void) {
  try {
    const q = query(collection(db, "customers"), orderBy("createdAt", "desc"));
    return onSnapshot(q, (snapshot) => {
      const customersList = snapshot.docs.map(docToCustomer);
      onUpdate(customersList);
    }, (error) => {
      handleFirestoreError(error, "subscribe", "customers");
      if (onError) onError(error);
    });
  } catch (error) {
    console.error("Failed to setup customers subscription:", error);
    return () => {};
  }
}

export async function addCustomer(customer: Partial<Customer>): Promise<string | null> {
  try {
    const collRef = collection(db, "customers");
    const docData = {
      customerName: customer.name || "New Lead",
      name: customer.name || "New Lead",
      company: customer.company || "Unknown Inc.",
      email: customer.email || "",
      phone: customer.phone || "",
      office: customer.office || customer.city || "",
      city: customer.city || customer.office || "",
      leadSource: customer.leadSource || "Direct Referral",
      status: customer.status || "New",
      lastFollowUpDate: customer.lastFollowUpDate || new Date().toISOString().split('T')[0],
      lastFollowUpRel: customer.lastFollowUpRel || "Today",
      avatarInitials: customer.avatarInitials || "NL",
      isVip: !!customer.isVip,
      assignedTo: customer.assignedTo || "",
      remark: customer.remark || "",
      createdAt: serverTimestamp()
    };
    const docRef = await addDoc(collRef, docData);
    return docRef.id;
  } catch (error) {
    handleFirestoreError(error, "add", "customers");
    return null;
  }
}

export async function updateCustomer(id: string, updates: Partial<Customer>): Promise<boolean> {
  try {
    const docRef = doc(db, "customers", id);
    const payload: any = { ...updates };
    if (updates.name !== undefined) {
      payload.customerName = updates.name; // match requested database field
    }
    if (updates.office !== undefined) {
      payload.city = updates.office; // match requested database field
    }
    await updateDoc(docRef, payload);
    return true;
  } catch (error) {
    handleFirestoreError(error, "update", "customers");
    return false;
  }
}

export async function deleteCustomer(id: string): Promise<boolean> {
  try {
    const docRef = doc(db, "customers", id);
    await deleteDoc(docRef);
    return true;
  } catch (error) {
    handleFirestoreError(error, "delete", "customers");
    return false;
  }
}

// Seed helper for initial customers list
export async function seedInitialCustomers(initialList: Customer[]): Promise<void> {
  try {
    const q = query(collection(db, "customers"));
    const snap = await getDocs(q);
    if (snap.empty) {
      console.log("Seeding initial customers into Firestore...");
      for (const item of initialList) {
        await addCustomer(item);
      }
    }
  } catch (error) {
    console.warn("Seeding customers failed (likely permission issues or disconnected database):", error);
  }
}

// -------------------------------------------------------------------------
// 3. CHANNELS FOR FOLLOW-UPS
// -------------------------------------------------------------------------

export function subscribeFollowUps(onUpdate: (followups: FollowUp[]) => void, onError?: (err: any) => void) {
  try {
    const q = query(collection(db, "followups"), orderBy("createdAt", "desc"));
    return onSnapshot(q, (snapshot) => {
      const followUpList: FollowUp[] = snapshot.docs.map(d => {
        const data = d.data();
        return {
          id: d.id,
          customerId: data.customerId || "",
          customerName: data.customerName || "",
          phone: data.phone || "",
          city: data.city || "",
          status: data.status || "Pending",
          followUpDate: data.followUpDate || "",
          assignedTo: data.assignedTo || "",
          remark: data.remark || "",
          createdAt: data.createdAt
        };
      });
      onUpdate(followUpList);
    }, (error) => {
      handleFirestoreError(error, "subscribe", "followups");
      if (onError) onError(error);
    });
  } catch (error) {
    console.error("Failed to setup followups subscription:", error);
    return () => {};
  }
}

export async function addFollowUp(followup: Partial<FollowUp>): Promise<string | null> {
  try {
    const collRef = collection(db, "followups");
    const docData = {
      customerId: followup.customerId || "",
      customerName: followup.customerName || "",
      phone: followup.phone || "",
      city: followup.city || "",
      status: followup.status || "Pending",
      followUpDate: followup.followUpDate || "",
      assignedTo: followup.assignedTo || "",
      remark: followup.remark || "",
      createdAt: serverTimestamp()
    };
    const docRef = await addDoc(collRef, docData);
    return docRef.id;
  } catch (error) {
    handleFirestoreError(error, "add", "followups");
    return null;
  }
}

export async function updateFollowUp(id: string, updates: Partial<FollowUp>): Promise<boolean> {
  try {
    const docRef = doc(db, "followups", id);
    await updateDoc(docRef, updates);
    return true;
  } catch (error) {
    handleFirestoreError(error, "update", "followups");
    return false;
  }
}

export async function deleteFollowUp(id: string): Promise<boolean> {
  try {
    const docRef = doc(db, "followups", id);
    await deleteDoc(docRef);
    return true;
  } catch (error) {
    handleFirestoreError(error, "delete", "followups");
    return false;
  }
}

export async function seedInitialFollowUps(customers: Customer[]): Promise<void> {
  try {
    const q = query(collection(db, "followups"));
    const snap = await getDocs(q);
    if (snap.empty) {
      console.log("Seeding initial followups based on customer lists...");
      const mockDates = [
        new Date().toISOString().split('T')[0], // Today
        new Date(Date.now() + 86400000).toISOString().split('T')[0], // Tomorrow
        new Date(Date.now() - 86400000).toISOString().split('T')[0], // Yesterday
      ];
      
      const seedData = [
        {
          customerName: "Alex Sterling",
          customerId: "as-1",
          phone: "+1 (555) 348-1124",
          city: "Seattle, WA, USA",
          status: "Pending" as const,
          followUpDate: mockDates[0], // Today
          assignedTo: "admin@company.com",
          remark: "Discuss fleet maintenance solution package terms",
        },
        {
          customerName: "Maya Kovic",
          customerId: "mk-2",
          phone: "+1 (555) 789-3221",
          city: "Austin, TX, USA",
          status: "Pending" as const,
          followUpDate: mockDates[0], // Today
          assignedTo: "staff@company.com",
          remark: "Pitch Enterprise trial subscription option",
        },
        {
          customerName: "Marcus Jenkins",
          customerId: "mj-6",
          phone: "+1 (555) 671-8890",
          city: "Houston, TX, USA",
          status: "Pending" as const,
          followUpDate: mockDates[1], // Tomorrow
          assignedTo: "staff@company.com",
          remark: "Follow up call to answer questions from webinar",
        },
        {
          customerName: "Sarah Miller",
          customerId: "sm-4",
          phone: "+1 (555) 123-9876",
          city: "New York, NY, USA",
          status: "Pending" as const,
          followUpDate: mockDates[2], // Yesterday / Overdue
          assignedTo: "admin@company.com",
          remark: "Re-engage cold contact regarding Q4 budget",
        }
      ];

      for (const item of seedData) {
        // Look up custom match
        const matchingCust = customers.find(c => c.name === item.customerName);
        await addFollowUp({
          ...item,
          customerId: matchingCust ? matchingCust.id : item.customerId
        });
      }
    }
  } catch (error) {
    console.warn("Seeding followups failed (likely permission parameters):", error);
  }
}
